# ============================================================
# Arcstone 环境变量配置模板
#
# 以下配置项均可在前端「设置」面板中填写，无需手动编辑此文件。
# 如果你更习惯 .env 方式，可复制本文件为 .env 并填入实际值。
# 前端设置面板的值会覆盖 .env 中的值。
# ============================================================

# --- 模型 API Keys ---
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_SUB_TOKEN=
OPENAI_API_KEY=
TAVILY_API_KEY=
MINERU_API_KEY=

# --- 阿里云百炼知识库 ---
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
BAILIAN_WORKSPACE_ID=

# --- 其他（不在设置面板，需手动配置） ---
PYTHON_EXECUTABLE=python
